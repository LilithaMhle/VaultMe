# ─────────────────────────────────────────────────────────
# VaultMe — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port the Express server listens on (default: 3000)
PORT=3000

# Allowed origin for CORS — set to your deployed frontend URL in production
# In development, http://localhost:3000 or file:// origins are allowed automatically
ALLOWED_ORIGIN=http://localhost:3000
